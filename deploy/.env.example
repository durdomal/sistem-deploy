# Скопируй в /opt/sistem/deploy/.env и заполни реальными значениями.
# НИКОГДА не коммить .env. Только .env.example.

# Postgres
POSTGRES_USER=sistem
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sistem

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT (RS256). Сгенерь пару:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# и вставь целиком с переводами строк заменёнными на \n.
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# AES-GCM ключ для шифрования секретов в Project Pack (256 бит, base64).
# Сгенерь: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
SISTEM_SECRETS_KEY=CHANGE_ME_BASE64_32BYTES

# Sentry (опционально)
SENTRY_DSN=

# Env
SISTEM_ENV=production


# ─ Sprint 2 (n8n) ─
N8N_HOST=n8n.globria.biz
N8N_BASIC_AUTH_USER=taras
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# ─ Sprint 3 (Claude Code daemon) ─
# Anthropic API key для headless CC на сервере
ANTHROPIC_API_KEY=
# HMAC-секрет между Sistem Core и cc-daemon (openssl rand -hex 32)
CC_DAEMON_SECRET=CHANGE_ME_HEX_64
# URL cc-daemon для Sistem Core (обычно внутренний docker net)
CC_DAEMON_URL=http://cc-daemon:8020

# Опциональные интеграции (n8n workflows подхватят когда есть)
APIFY_TOKEN=
FIRECRAWL_API_KEY=
POSTIZ_BASE_URL=
POSTIZ_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT=
SISTEM_JWT=  # long-lived JWT для n8n → sistem вызовов
